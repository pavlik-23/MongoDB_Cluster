services:
  {{ service_name | default('ansible-mongo') }}:
    image: {{ mongo_image }}
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    cap_add:
      - IPC_LOCK

    mem_limit: {{ mem_limit }}
    restart: always

    network_mode: "host"
#    ports:
#      - "{{ mongo_port }}:{{ mongo_port }}"

    volumes:
      - "./mongodb_data:/var/lib/mongodb:rw"
      - "./mongod.conf:/etc/mongod.conf:rw"
      - "./mongodb_log:/var/log/mongodb"

    entrypoint:
      - "/usr/local/bin/docker-entrypoint.sh"
    command: "mongod --config /etc/mongod.conf"


    healthcheck:
      test: ["CMD", "mongosh", "--quiet", "--eval", "db.adminCommand({ ping: 1 })"]
      interval: 10s
      timeout: 5s
      retries: 10


