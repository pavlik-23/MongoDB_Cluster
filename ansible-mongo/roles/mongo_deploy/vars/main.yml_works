---
    project_name: mongodb_27017
    service_name: test_ansible
    mongo_image: 'mongo:8.0.0'
    mem_limit: '4096m'

    cache_size: '2'
    opolog_size: '1024'
    mongo_port: 27017

    path: "/storage/mongodb/{{ project_name }}"
    replicaset_name: '{{ project_name }}'

#    check_ports: [ "{{ mongo_port }}" ]
 
    mongo_rs_verbose: false
